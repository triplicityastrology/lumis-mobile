{
  "name": "lumis-mobile",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "pnpm --filter @lumis/mobile start",
    "ios": "pnpm --filter @lumis/mobile ios",
    "android": "pnpm --filter @lumis/mobile android",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "test:router": "tsc -p packages/shared/tsconfig.router-test.json && node .tmp/router-tests/config/chat-router.fixtures.js",
    "test:dice": "tsc -p apps/mobile/tsconfig.dice-test.json && node .tmp/dice-tests/features/dice/dice.fixtures.js",
    "test:birth-date": "tsc -p packages/shared/tsconfig.birth-date-test.json && node .tmp/birth-date-tests/config/birth-date.fixtures.js",
    "test:birth-location": "node scripts/birth-location-contract.mjs",
    "test:entitlement": "tsc -p packages/shared/tsconfig.entitlement-test.json && node .tmp/entitlement-tests/config/account-entitlement.fixtures.js",
    "test:billing-entitlement": "node scripts/billing-entitlement-contract.mjs",
    "test:care-circle": "node scripts/care-circle-contract.mjs",
    "test:golden": "tsc -p packages/astrology/tsconfig.golden-test.json && node .tmp/golden-chart-tests/astrology/src/golden-charts.fixtures.js",
    "test:golden-live": "node scripts/golden-chart-live.mjs",
    "test:golden-live:secure": "bash scripts/run-golden-chart-live.sh",
    "test:worker": "node --check workers/chart-mobile/worker.js && node workers/chart-mobile/worker.fixtures.mjs",
    "test:profile": "tsc -p packages/astrology/tsconfig.profile-test.json && node .tmp/profile-onboarding-tests/astrology/src/profile-onboarding.fixtures.js && node supabase/functions/profile/profile-recovery-contract.fixtures.mjs",
    "test:chat-persistence": "node supabase/functions/chat-message/chat-persistence.fixtures.mjs",
    "test:staging-backend": "node scripts/staging-backend-smoke.mjs",
    "test:staging-backend:secure": "bash scripts/run-staging-backend-test.sh",
    "test:staging-backend:cleanup": "bash scripts/run-staging-backend-test.sh cleanup",
    "test:account-deletion-db": "node scripts/staging-backend-smoke.mjs",
    "test:worker-live": "node scripts/cloudflare-worker-smoke.mjs",
    "test:external-sync": "node scripts/external-sync-contract.mjs",
    "test:mobile-ui": "node scripts/mobile-ui-contract.mjs",
    "test:backend-guardrails": "node scripts/backend-guardrails-contract.mjs",
    "test:route-credits": "node scripts/route-credit-drift.mjs",
    "test:pii": "node scripts/repository-pii-scan.mjs",
    "test:birth-details-change": "node scripts/birth-details-regeneration-contract.mjs",
    "test:all-local": "pnpm test:router && pnpm test:dice && pnpm test:birth-date && pnpm test:birth-location && pnpm test:entitlement && pnpm test:billing-entitlement && pnpm test:care-circle && pnpm test:golden && pnpm test:worker && pnpm test:profile && pnpm test:chat-persistence && pnpm test:external-sync && pnpm test:mobile-ui && pnpm test:backend-guardrails && pnpm test:route-credits && pnpm test:pii && pnpm test:birth-details-change",
    "external-sync:report": "node scripts/external-sync-admin.mjs report",
    "external-sync:replay": "node scripts/external-sync-admin.mjs replay",
    "external-sync:resolve": "node scripts/external-sync-admin.mjs resolve"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  }
}
