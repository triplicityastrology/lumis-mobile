{
  "name": "lumis-mobile",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "pnpm --filter @lumis/mobile start",
    "ios": "pnpm --filter @lumis/mobile ios",
    "android": "pnpm --filter @lumis/mobile android",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "test:router": "tsc -p packages/shared/tsconfig.router-test.json && node .tmp/router-tests/config/chat-router.fixtures.js",
    "test:golden": "tsc -p packages/astrology/tsconfig.golden-test.json && node .tmp/golden-chart-tests/astrology/src/golden-charts.fixtures.js",
    "test:worker": "node --check workers/chart-mobile/worker.js && node workers/chart-mobile/worker.fixtures.mjs",
    "test:profile": "tsc -p packages/astrology/tsconfig.profile-test.json && node .tmp/profile-onboarding-tests/astrology/src/profile-onboarding.fixtures.js"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  }
}
