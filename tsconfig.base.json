{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@lumis/shared": ["packages/shared/src/index.ts"],
      "@lumis/astrology": ["packages/astrology/src/index.ts"],
      "@lumis/billing": ["packages/billing/src/index.ts"]
    }
  }
}

